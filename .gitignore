# Redis Enterprise GitOps - Git Ignore

# Temporary files
*.tmp
*.swp
*.swo
*~
.DS_Store

# IDE and editor files
.vscode/
.idea/
*.iml
.project
.classpath
.settings/

# Kustomize build output
kustomization-output/
rendered/

# Secrets (never commit secrets!)
*-secret.yaml
secrets/
*.key
*.crt
*.pem
!tls-demo/*.key
!tls-demo/*.crt
!tls-demo/*.pem
!customer-demos/certificates-manual/certs/*.key
!customer-demos/certificates-manual/certs/*.crt
!customer-demos/certificates-manual/certs/*.pem

# Local testing
test-output/
.test/

# CI/CD artifacts
.gitlab-ci-local/

# Backup files
*.bak
*.backup

# OS files
Thumbs.db

docs/*
!docs/ARGOCD_APP_OF_APPS_PRODUCT_PLAN.md

demo-gitops-argocd*/**/*
learning/*
customer-demos/*
