          "type": "loki",
          "uid": "${datasource}"
        },
        "regex": "/kubernetes_pod_name=\"([^\"]+)\"/",
        "allValue": ".*"
      },
      {
        "name": "file",
        "label": "Log File",
        "type": "query",
        "query": "query_result(sum by (kubernetes_container_name) (count_over_time({kubernetes_namespace_name=~\"$namespace\", kubernetes_pod_name=~\"$pod\"}[1h])))",
