  "templating": {
    "list": [
      {
        "name": "namespace",
        "label": "Namespace",
        "type": "query",
        "query": {
          "label": "kubernetes_namespace_name",
          "refId": "LokiVariableQueryEditor-VariableQuery",
          "stream": "{kubernetes_namespace_name=~\".+\"}",
          "type": 1
        },
        "definition": "label_values({kubernetes_namespace_name=~\".+\"}, kubernetes_namespace_name)",
        "includeAll": true,
        "allValue": ".+",
        "multi": true,
        "refresh": 1,
        "current": {
          "selected": true,
          "text": "All",
          "value": ".+"
        },
        "datasource": {
          "type": "loki",
          "uid": "${datasource}"
        }
      },
      {
        "name": "job",
        "label": "Job",
        "type": "query",
        "query": {
          "label": "job",
          "refId": "LokiVariableQueryEditor-VariableQuery",
          "stream": "{kubernetes_namespace_name=~\"$namespace\"}",
          "type": 1
        },
        "definition": "label_values({kubernetes_namespace_name=~\"$namespace\"}, job)",
        "includeAll": true,
        "allValue": ".+",
        "multi": true,
        "refresh": 1,
        "current": {
          "selected": true,
          "text": "All",
          "value": ".+"
        },
        "datasource": {
          "type": "loki",
          "uid": "${datasource}"
        }
      },
      {
        "name": "severity",
        "label": "Severity",
        "type": "custom",
        "query": "error|fatal|panic|critical|fail|exception|timeout|denied|oom|unhealthy,warn|warning,error|fatal|panic|critical|fail|exception|timeout|denied|oom|unhealthy|warn|warning,.*",
        "current": {
          "selected": true,
          "text": "error|fatal|panic|critical|fail|exception|timeout|denied|oom|unhealthy|warn|warning",
          "value": "error|fatal|panic|critical|fail|exception|timeout|denied|oom|unhealthy|warn|warning"
        }
      },
      {
        "name": "search",
        "label": "Text Search",
        "type": "textbox",
        "query": ".*",
        "current": {
          "selected": true,
          "text": ".*",
          "value": ".*"
        }
      }
    ]
